const rootClass = variant === 'hero' ? 'social social--hero' : 'social social--footer';
---

<div class={rootClass}>
  {label && <span class="social__label">{label}</span>}
  <div class="social__row">
    {links.map((link) => (
      <a
        href={link.href}
        aria-label={link.name}
        {...(link.href.startsWith('mailto:') ? {} : { target: '_blank', rel: link.rel })}
      >
        {link.email ? (
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        ) : (
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d={link.path} /></svg>
        )}
      </a>
    ))}
  </div>
</div>
